# ─── Application ──────────────────────────────────────────────────────────
APP_NAME="AI Restaurant Receptionist"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────
# Async URL used by FastAPI (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/restaurant_ai
# Sync URL used by Alembic (psycopg2)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/restaurant_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=800
OPENAI_TIMEOUT_SECONDS=30

# ─── Conversation memory ──────────────────────────────────────────────────
CONVERSATION_HISTORY_LIMIT=20

# ─── Restaurant configuration ─────────────────────────────────────────────
RESTAURANT_NAME="La Maison"
RESTAURANT_TIMEZONE=America/New_York
OPENING_HOUR=11
CLOSING_HOUR=22
MAX_PARTY_SIZE=12
MIN_PARTY_SIZE=1
RESERVATION_DURATION_MINUTES=90
MAX_DAILY_CAPACITY=80

# ─── Security / CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*
